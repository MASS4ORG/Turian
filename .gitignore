# Zig project ignores
# Build output directory (default for `zig build`)
**/zig-out/
**/.zig-cache/
**/zig-pkg/

# Temporary object files and executables
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# Any generated IDE/project files
*.log
*.tmp
*.bak
*.swp

# OSes
.DS_Store
*~

# LLMs
.claude/
.agents/

# IDE
.vscode/
.idea/
.zed/

# ...but Wavefront .obj meshes under an assets/ folder are real project
# assets, not C/C++ build artifacts — keep them tracked.
!**/assets/**/*.obj

# Turian stuff
.public/
**/.cache
docs/decisions/
local.zig
turian.sh
turian.py
