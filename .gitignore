# Zig project ignores
# Build output directory (default for `zig build`)
**/zig-out/
**/.zig-cache/
**/zig-pkg/

# Temporary object files and executables
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# ...but Wavefront .obj meshes under an assets/ folder are real project
# assets, not C/C++ build artifacts — keep them tracked.
!**/assets/**/*.obj

# Any generated IDE/project files
*.log
*.tmp
*.bak
*.swp

# Optional user-specific local overrides
local.zig

# macOS
.DS_Store

# Linux
*~

# LLMs
.claude/
.agents/

# IDE
.vscode/
.idea/
.zed/

# Release packaging output (release-package writes archives here)
.public/
**/.cache
docs/decisions/
